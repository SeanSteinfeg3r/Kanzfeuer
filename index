<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sportring Kanzfeuer 2026</title>
  <style>
    html, body { height:100%; margin:0; padding:0; }
