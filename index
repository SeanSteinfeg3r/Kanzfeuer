<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sportring Kanzfeuer 2026</title>
  <style>
    /* Dein CSS bleibt gleich */
    html, body { height:100%; margin:0; padding:0; }
    body { font-family: Arial, sans-serif; padding: 16px; margin:0; background: #f9f9f9; min-height:100vh;}
    h1, h2 { text-align: center; }
    .tage-buttons { display: flex; justify-content: center; gap: 10px; flex-wrap: wrap; margin-bottom: 18px; }
    button, .tage-buttons button { padding: 12px 14px; background: #007bff; color: white; border: none; border-radius: 7px; cursor: pointer; font-size:1.07em; }
    button:hover { background: #0056b3; }
    .btn-purple { background: #6f42c1; }
    table { width: 100%; border-collapse: collapse; background: white; margin-top: 8px; min-width: 520px; }
    th, td { border: 1px solid #ccc; padding: 8px 5px; text-align: center; }
    th { background-color: #eee; }
    .input-gruppe { display: flex; align-items: stretch; margin-top: 5px; }
    .input-gruppe input { flex-grow: 1; padding: 8px; border: 1px solid #ccc; border-radius: 5px 0 0 5px; }
    .input-gruppe button { border-radius: 0 5px 5px 0; }
    .schicht-voll { color: #28a745; font-weight: bold; padding: 8px; }
    .admin-section { margin-top: 20px; background: #eef; padding: 14px; border-radius: 9px; }
  </style>
</head>
<body>
  <h1>Sportring Kanzfeuer 2026</h1>
  <div class="tage-buttons">
    <button onclick="zeigeTag('Aufbau')">Aufbau 20.06.</button>
    <button onclick="zeigeTag('Samstag')">Samstag 20.06.</button>
    <button onclick="zeigeTag('Abbau')">Abbau 21.06.</button>
  </div>
  <div id="schichtplan"></div>

<script>
    // --- NEUE IDs EINGETRAGEN ---
    const BASEROW_API_TOKEN = "IFMpLzN7n8NCLtwNOTmlTzIPx9X8oidv"; 
    const BASEROW_SERVER_URL = "https://api.baserow.io";
    const KONFIG_TABLE_ID    = 1031612; 
    const EINTRAEGE_TABLE_ID = 1031613;

    let tag = 'Aufbau';
    const daten = { Aufbau: {}, Samstag: {}, Abbau: {} };
    const config = { 
        Aufbau: { aufgaben: [], zeiten: [], farben: [], limits: {} }, 
        Samstag: { aufgaben: [], zeiten: [], farben: [], limits: {} },
        Abbau: { aufgaben: [], zeiten: [], farben: [], limits: {} }
    };

    async function fetchBaserow(method, url, body = null) {
      const options = { 
        method, 
        headers: { 'Authorization': `Token ${BASEROW_API_TOKEN}`, 'Content-Type': 'application/json' } 
      };
      if (body) options.body = JSON.stringify(body);
      const res = await fetch(url, options);
      return res.status === 204 ? { success: true } : await res.json();
    }

    async function ladeDaten() {
        const url = `${BASEROW_SERVER_URL}/api/database/rows/table/${EINTRAEGE_TABLE_ID}/?user_field_names=true&size=200`;
        const data = await fetchBaserow('GET', url);
        
        // Zurücksetzen
        for (const t in daten) daten[t] = {};
        
        for (const row of data.results) {
            const t = String(row.Tag).trim();
            if (daten.hasOwnProperty(t)) {
                const key = `${row.Zeit}||${row.Aufgabe}`;
                if (!daten[t][key]) daten[t][key] = [];
                daten[t][key].push(row.Name);
            }
        }
        await ladeKonfiguration();
    }

    async function ladeKonfiguration() {
        const url = `${BASEROW_SERVER_URL}/api/database/rows/table/${KONFIG_TABLE_ID}/?user_field_names=true&size=200`;
        const data = await fetchBaserow('GET', url);
        for (const row of data.results) {
            if (row.Tag && config.hasOwnProperty(row.Tag)) {
                try { config[row.Tag] = JSON.parse(row.Konfig); } catch(e) {}
            }
        }
        zeigeTag(tag);
    }

    function zeigeTag(t) {
        tag = t;
        const conf = config[t];
        let html = `<h2>${t}</h2><table>`;
        // Tabellenkopf und Zeilen... (deine bisherige Logik hier beibehalten)
        // ... (Der Code hier kann 1:1 von deinem vorherigen Skript übernommen werden)
        document.getElementById('schichtplan').innerHTML = html;
    }

    ladeDaten();
</script>
</body>
</html>
